{
  "name": "mir-prep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "scrape": "tsx scripts/scrape-mir.ts",
    "generate-data": "tsx scripts/generate-sample-data.ts",
    "generate-resumenes": "tsx scripts/generate-resumenes.ts",
    "seed": "tsx scripts/seed.ts",
    "db:seed": "tsx scripts/generate-sample-data.ts && tsx scripts/generate-resumenes.ts && tsx scripts/seed.ts",
    "db:push": "npx prisma db push",
    "db:reset": "npx prisma db push --force-reset && npm run db:seed",
    "seed:universidades": "tsx scripts/seed-university-questions.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@marsidev/react-turnstile": "^1.5.3",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/adapter-pg-worker": "^6.9.0",
    "@prisma/client": "^7.6.0",
    "@prisma/pg-worker": "^6.9.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "framer-motion": "^12.38.0",
    "mammoth": "^1.12.0",
    "next": "16.2.2",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
